{
  "name": "chain-clarity-lab",
  "version": "1.0.0",
  "description": "Blockchain research, smart contracts, and Web3 project trials by Elias Kfoury — @chainclar",
  "author": "Elias Kfoury <n.satoshi@gmx.com>",
  "license": "MIT",
  "homepage": "https://chainclarify.netlify.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/chainclar/chain-clarity-lab.git"
  },
  "keywords": [
    "blockchain",
    "ethereum",
    "solidity",
    "smart-contracts",
    "defi",
    "web3",
    "post-quantum",
    "healthcare-blockchain",
    "supply-chain",
    "dao"
  ],
  "scripts": {
    "compile":      "npx hardhat compile",
    "test":         "npx hardhat test",
    "test:gas":     "REPORT_GAS=true npx hardhat test",
    "deploy:local": "npx hardhat run scripts/deploy.js --network localhost",
    "deploy:goerli":"npx hardhat run scripts/deploy.js --network goerli",
    "node":         "npx hardhat node",
    "lint":         "npx solhint 'smart-contracts/**/*.sol'",
    "coverage":     "npx hardhat coverage",
    "clean":        "npx hardhat clean"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@nomiclabs/hardhat-etherscan": "^3.1.7",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.9",
    "solidity-coverage": "^0.8.5",
    "chai": "^4.3.10",
    "ethers": "^6.9.0",
    "solhint": "^4.1.1"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.3.1"
  }
}
